# ─────────────────────────────────────────────────────────────────────────────
# Azure OpenAI  (required)
# ─────────────────────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-12-01-preview
USE_AZURE=true

# ─────────────────────────────────────────────────────────────────────────────
# Scraper - Core Settings
# ─────────────────────────────────────────────────────────────────────────────

# Strategy to run: videsktop | all
STRATEGY=videsktop

# Role to search for across all firms
ROLE=business professional

# Max concurrent browser sessions
CONCURRENCY=5

# Output file path
OUTPUT_FILE=output.txt

# Filter to a single firm by name substring, or "all" for all firms
SITE_FILTER=all

# ─────────────────────────────────────────────────────────────────────────────
# Browser Settings
# ─────────────────────────────────────────────────────────────────────────────

# Must be true in production / container environments (no display available)
HEADLESS=true

VERBOSE_ACTIONS=false
SAVE_GIF=false
SAVE_CONVERSATION=false

# Seconds before a single site scrape is aborted
SCRAPE_TIMEOUT=300

# ─────────────────────────────────────────────────────────────────────────────
# Storage
# ─────────────────────────────────────────────────────────────────────────────

# local | cosmos
STORAGE=local

# Required only when STORAGE=cosmos
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-primary-key
# COSMOS_DATABASE=hr-scraper
# COSMOS_CONTAINER=job-results
